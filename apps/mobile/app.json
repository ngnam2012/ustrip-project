{
  "expo": {
    "name": "UsTrip",
    "slug": "ustrip",
    "scheme": "ustrip",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      "expo-notifications"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "vn.ustrip.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "vn.ustrip.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "22f6e122-0088-40c5-97bf-f8e76248a8bd"
      }
    },
    "owner": "ngnam2012"
  }
}
