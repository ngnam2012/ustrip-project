{
  "name": "ustrip-project",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names API,WEB,MOBILE --prefix-colors blue,green,magenta \"npm run dev:server\" \"npm run dev:web\" \"npm run dev:mobile\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:mobile": "npm run start -w apps/mobile",
    "dev:server": "cd server && uvicorn src.main:socket_app --host 0.0.0.0 --port 5000 --reload",
    "check": "npm run build -w apps/web",
    "db:push": "node database/migrate.js"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "concurrently": "^9.1.2",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "react-native-reanimated": "4.1.1",
    "react-native-worklets": "0.5.1"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
